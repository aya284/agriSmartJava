<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.*?>

<StackPane style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.user.LoginController">

    <VBox alignment="CENTER" maxHeight="740" maxWidth="460" prefHeight="740" prefWidth="460" spacing="22" style="-fx-background-color: white;                  -fx-background-radius: 20;                  -fx-padding: 50 55 40 55;                  -fx-border-color: #e5e7eb;                  -fx-border-width: 1;                  -fx-border-radius: 20;                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 28, 0.0, 0, 14);">

        <!-- Header -->
        <VBox alignment="CENTER" spacing="6">
            <Label style="-fx-text-fill: #2a5438;                           -fx-font-size: 36px;                           -fx-font-weight: bold;" text="AgriSmart" />
            <Label style="-fx-text-fill: #555555;                           -fx-font-size: 16px;" text="Connectez-vous à votre compte" />
        </VBox>

        <!-- Form -->
        <VBox maxWidth="340" prefHeight="238.0" prefWidth="320.0" spacing="18">

            <!-- Email -->
            <VBox spacing="6">
                <Label style="-fx-text-fill: #2a5438; -fx-font-size: 13px; -fx-font-weight: bold;" text="Adresse e-mail" />
                <TextField fx:id="emailField" promptText="Entrez votre adresse e-mail" style="-fx-background-color: #f8f9fa;                                   -fx-background-radius: 12;                                   -fx-border-color: #d1d5db;                                   -fx-border-width: 1;                                   -fx-padding: 14 16;                                   -fx-font-size: 15px;" />
            </VBox>

            <!-- Password -->
            <VBox spacing="6">
                <Label style="-fx-text-fill: #2a5438; -fx-font-size: 13px; -fx-font-weight: bold;" text="Mot de passe" />
                <PasswordField fx:id="passwordField" promptText="Entrez votre mot de passe" style="-fx-background-color: #f8f9fa;                                       -fx-background-radius: 12;                                       -fx-border-color: #d1d5db;                                       -fx-border-width: 1;                                       -fx-padding: 14 16;                                       -fx-font-size: 15px;" />
            </VBox>

            <!-- Forgot Password -->
            <HBox alignment="CENTER_RIGHT">
                <Hyperlink onAction="#goToForgotPassword" style="-fx-text-fill: #2a5438; -fx-font-size: 12.5px;" text="Mot de passe oublié ?" />
            </HBox>

        </VBox>

        <!-- Error Label -->
        <Label fx:id="errorLabel" alignment="CENTER" maxWidth="340" style="-fx-text-fill: #e74c3c; -fx-font-size: 13.5px;" visible="false" wrapText="true" />

        <!-- Login Button -->
        <Button fx:id="loginBtn" maxWidth="340" onAction="#handleLogin" style="-fx-background-color: #2a5438;                        -fx-text-fill: white;                        -fx-font-weight: bold;                        -fx-font-size: 16px;                        -fx-background-radius: 12;                        -fx-padding: 14 20;" text="Se connecter" />

        <!-- Divider -->
        <HBox alignment="CENTER" maxWidth="340" spacing="10">
            <Separator HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: #9ca3af; -fx-font-size: 12px; -fx-font-weight: bold;" text="OU" />
            <Separator HBox.hgrow="ALWAYS" />
        </HBox>

        <!-- Google Button -->
        <Button fx:id="googleBtn" maxWidth="340" onAction="#handleGoogleLogin" style="-fx-background-color: white;                        -fx-text-fill: #374151;                        -fx-font-weight: bold;                        -fx-font-size: 15px;                        -fx-background-radius: 12;                        -fx-border-color: #d1d5db;                        -fx-border-width: 1.5;                        -fx-border-radius: 12;                        -fx-padding: 12 20;" text="🔵  Continuer avec Google" />

        <!-- Register Link -->
        <HBox alignment="CENTER" spacing="8">
            <Label style="-fx-text-fill: #6b7280; -fx-font-size: 14.5px;" text="Vous n'avez pas de compte ?" />
            <Hyperlink onAction="#goToRegister" style="-fx-text-fill: #E6BF4A;                               -fx-font-weight: bold;                               -fx-font-size: 14.5px;" text="S'inscrire" />
        </HBox>

    </VBox>
</StackPane>
