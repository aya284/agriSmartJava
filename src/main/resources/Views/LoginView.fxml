<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/17"
           fx:controller="controllers.user.LoginController"
           style="-fx-background-color: #f8f9fa;">

    <!-- Larger centered card -->
    <VBox spacing="30"
          alignment="CENTER"
          prefWidth="460"
          prefHeight="520"
          maxWidth="460"
          maxHeight="520"
          style="-fx-background-color: white;
                 -fx-background-radius: 20;
                 -fx-padding: 50 55 50 55;
                 -fx-border-color: #e5e7eb;
                 -fx-border-width: 1;
                 -fx-border-radius: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 28, 0.0, 0, 14);">

        <!-- Header -->
        <VBox spacing="6" alignment="CENTER">
            <Label text="AgriSmart"
                   style="-fx-text-fill: #2a5438;
                          -fx-font-size: 36px;
                          -fx-font-weight: bold;"/>
            <Label text="Connectez-vous à votre compte"
                   style="-fx-text-fill: #555555;
                          -fx-font-size: 16px;"/>
        </VBox>

        <!-- Form Fields -->
        <VBox spacing="20" maxWidth="340">

            <!-- Email -->
            <VBox spacing="6">
                <Label text="Adresse e-mail"
                       style="-fx-text-fill: #2a5438;
                              -fx-font-size: 13px;
                              -fx-font-weight: bold;"/>
                <TextField fx:id="emailField"
                           promptText="Entrez votre adresse e-mail"
                           style="-fx-background-color: #f8f9fa;
                                  -fx-background-radius: 12;
                                  -fx-border-color: #d1d5db;
                                  -fx-border-width: 1;
                                  -fx-padding: 14 16;
                                  -fx-font-size: 15px;"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="6">
                <Label text="Mot de passe"
                       style="-fx-text-fill: #2a5438;
                              -fx-font-size: 13px;
                              -fx-font-weight: bold;"/>
                <PasswordField fx:id="passwordField"
                               promptText="Entrez votre mot de passe"
                               style="-fx-background-color: #f8f9fa;
                                      -fx-background-radius: 12;
                                      -fx-border-color: #d1d5db;
                                      -fx-border-width: 1;
                                      -fx-padding: 14 16;
                                      -fx-font-size: 15px;"/>
            </VBox>

            <!-- Forgot Password -->
            <HBox alignment="CENTER_RIGHT">
                <Hyperlink text="Mot de passe oublié ?"
                           onAction="#goToForgotPassword"
                           style="-fx-text-fill: #2a5438;
                                  -fx-font-size: 12.5px;"/>
            </HBox>
        </VBox>

        <!-- Error Label -->
        <Label fx:id="errorLabel"
               style="-fx-text-fill: #e74c3c;
                      -fx-font-size: 13.5px;"
               visible="false"
               maxWidth="Infinity"
               alignment="CENTER"/>

        <!-- Sign In Button -->
        <Button fx:id="loginBtn"
                text="Se connecter"
                onAction="#handleLogin"
                maxWidth="340"
                style="-fx-background-color: #2a5438;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-font-size: 16px;
                       -fx-background-radius: 12;
                       -fx-padding: 14 20;"/>

        <!-- Register Link -->
        <HBox alignment="CENTER" spacing="8">
            <Label text="Vous n'avez pas de compte ?"
                   style="-fx-text-fill: #6b7280;
                          -fx-font-size: 14.5px;"/>
            <Hyperlink text="S'inscrire"
                       onAction="#goToRegister"
                       style="-fx-text-fill: #E6BF4A;
                              -fx-font-weight: bold;
                              -fx-font-size: 14.5px;"/>
        </HBox>

    </VBox>
</StackPane>