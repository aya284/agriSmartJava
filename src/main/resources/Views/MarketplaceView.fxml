<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.MarketplaceController"
      spacing="14"
      styleClass="feature-page">

    <VBox styleClass="feature-hero" spacing="14">
        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="2">
                <Label text="Marketplace AgriSmart" styleClass="feature-title"/>
                <Label text="Produits agricoles en vente ou en location" styleClass="feature-subtitle"/>
            </VBox>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="Chargement..." styleClass="status-label"/>
        </HBox>

        <HBox spacing="10">
            <Button text="Espace vendeur" styleClass="action-chip"/>
            <Button text="Messagerie" styleClass="action-chip gold"/>
            <Button text="Publier une annonce" styleClass="action-chip primary" onAction="#openAjouterProduit"/>
            <Button text="Panier" styleClass="action-chip"/>
        </HBox>

        <HBox spacing="10" styleClass="module-chip-row">
            <Button text="Toutes" styleClass="module-chip active"/>
            <Button text="Legumes" styleClass="module-chip"/>
            <Button text="Fruits" styleClass="module-chip"/>
            <Button text="Cereales" styleClass="module-chip"/>
            <Button text="Engrais" styleClass="module-chip"/>
            <Button text="Semences" styleClass="module-chip"/>
            <Button text="Materiel" styleClass="module-chip"/>
            <Button text="Irrigation" styleClass="module-chip"/>
            <Button text="Services" styleClass="module-chip"/>
        </HBox>
    </VBox>

    <HBox spacing="12">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Produits" styleClass="stat-title"/>
            <Label fx:id="statProduits" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Commandes" styleClass="stat-title"/>
            <Label fx:id="statCommandes" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Wishlist" styleClass="stat-title"/>
            <Label fx:id="statWishlist" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Messages" styleClass="stat-title"/>
            <Label fx:id="statMessages" text="0" styleClass="stat-value"/>
        </VBox>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="filter-row">
        <TextField fx:id="searchField" promptText="Search by product name or category" onKeyReleased="#handleSearch" HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="typeFilterCombo" onAction="#handleFilterChange" prefWidth="140"/>
        <ComboBox fx:id="promoFilterCombo" onAction="#handleFilterChange" prefWidth="160"/>
    </HBox>

    <TabPane VBox.vgrow="ALWAYS">

        <Tab text="Produits" closable="false">
            <VBox spacing="8" prefHeight="420">
                <HBox alignment="CENTER_RIGHT">
                    <Button text="+ Add Produit" styleClass="btn-primary" onAction="#openAjouterProduit"/>
                </HBox>
                <TableView fx:id="produitTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="70"/>
                        <TableColumn fx:id="colNom" text="Nom" prefWidth="180"/>
                        <TableColumn fx:id="colType" text="Type" prefWidth="120"/>
                        <TableColumn fx:id="colCategorie" text="Categorie" prefWidth="150"/>
                        <TableColumn fx:id="colPrix" text="Prix" prefWidth="120"/>
                        <TableColumn fx:id="colStock" text="Stock" prefWidth="120"/>
                        <TableColumn fx:id="colPromo" text="Promo" prefWidth="110"/>
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="220"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <Tab text="Commandes" closable="false">
            <VBox spacing="8" prefHeight="420">
                <HBox alignment="CENTER_RIGHT">
                    <Button text="+ Add Commande" styleClass="btn-primary" onAction="#openAjouterCommande"/>
                </HBox>
                <TableView fx:id="commandeTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colCmdId" text="ID" prefWidth="80"/>
                        <TableColumn fx:id="colCmdStatut" text="Statut" prefWidth="180"/>
                        <TableColumn fx:id="colCmdMontant" text="Montant" prefWidth="130"/>
                        <TableColumn fx:id="colCmdPaiement" text="Paiement" prefWidth="170"/>
                        <TableColumn fx:id="colCmdActions" text="Actions" prefWidth="220"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <Tab text="Wishlist" closable="false">
            <VBox spacing="8" prefHeight="420">
                <HBox alignment="CENTER_RIGHT">
                    <Button text="+ Add Wishlist" styleClass="btn-primary" onAction="#openAjouterWishlist"/>
                </HBox>
                <TableView fx:id="wishlistTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colWishId" text="ID" prefWidth="90"/>
                        <TableColumn fx:id="colWishUser" text="User ID" prefWidth="170"/>
                        <TableColumn fx:id="colWishProduit" text="Produit ID" prefWidth="170"/>
                        <TableColumn fx:id="colWishActions" text="Actions" prefWidth="220"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <Tab text="Messages" closable="false">
            <VBox spacing="8" prefHeight="420">
                <HBox alignment="CENTER_RIGHT">
                    <Button text="+ Add Message" styleClass="btn-primary" onAction="#openAjouterMessage"/>
                </HBox>
                <TableView fx:id="messageTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colMsgId" text="ID" prefWidth="80"/>
                        <TableColumn fx:id="colMsgConversation" text="Conversation ID" prefWidth="170"/>
                        <TableColumn fx:id="colMsgSender" text="Sender ID" prefWidth="130"/>
                        <TableColumn fx:id="colMsgContent" text="Content" prefWidth="250"/>
                        <TableColumn fx:id="colMsgRead" text="Read" prefWidth="100"/>
                        <TableColumn fx:id="colMsgActions" text="Actions" prefWidth="220"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

    </TabPane>
</VBox>
