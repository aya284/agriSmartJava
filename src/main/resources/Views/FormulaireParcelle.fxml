<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.FormulaireParcelleController" spacing="25" prefWidth="850" prefHeight="600" styleClass="panel-card">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <VBox spacing="5">
        <Label fx:id="lblTitle" text="Gestion de la Parcelle" styleClass="module-title"/>
        <Label text="Localisez votre terrain sur la carte pour remplir les coordonnées automatiquement." styleClass="status-label"/>
    </VBox>

    <HBox spacing="25" VBox.vgrow="ALWAYS">
        <!-- Section Champs (Gaucher) -->
        <VBox spacing="20" prefWidth="350" styleClass="form-section">
            <Label text="Informations Générales" styleClass="panel-title" style="-fx-font-size: 14px;"/>
            
            <GridPane vgap="15" hgap="10">
                <columnConstraints>
                    <ColumnConstraints prefWidth="120"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Nom :" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="panel-muted"/>
                <TextField fx:id="txtNom" promptText="Saisir ou cliquer sur la carte" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Surface (Ha) :" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="panel-muted"/>
                <TextField fx:id="txtSurface" promptText="Ex: 5.2" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Type de Sol :" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="panel-muted"/>
                <TextField fx:id="txtType" promptText="Ex: Sablonneux" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>

            <Separator/>
            
            <Label text="Coordonnées Géographiques" styleClass="panel-title" style="-fx-font-size: 14px;"/>
            <GridPane vgap="15" hgap="10">
                 <columnConstraints>
                    <ColumnConstraints prefWidth="120"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Latitude :" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="panel-muted"/>
                <TextField fx:id="txtLat" editable="false" style="-fx-background-color: #f8f9fa;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Longitude :" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="panel-muted"/>
                <TextField fx:id="txtLon" editable="false" style="-fx-background-color: #f8f9fa;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            </GridPane>
        </VBox>

        <!-- Section Carte (Droite) -->
        <VBox spacing="10" HBox.hgrow="ALWAYS">
            <Label text="Sélecteur d'emplacement" styleClass="panel-title" style="-fx-font-size: 14px;"/>
            <StackPane VBox.vgrow="ALWAYS" style="-fx-border-color: #dce8df; -fx-border-radius: 10; -fx-background-radius: 10; -fx-overflow-hidden: true;">
                <WebView fx:id="webViewFormMap"/>
            </StackPane>
        </VBox>
    </HBox>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Abandonner" onAction="#cancel" styleClass="btn-danger" style="-fx-background-color: transparent; -fx-text-fill: #c94f52;"/>
        <Button text="Enregistrer la Parcelle" onAction="#save" styleClass="btn-primary" prefWidth="180"/>
    </HBox>
</VBox>
