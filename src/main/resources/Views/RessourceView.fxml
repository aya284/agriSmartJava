<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.RessourceController" spacing="20" styleClass="feature-page">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <VBox>
            <Label text="Gestion des Ressources" styleClass="module-title"/>
            <Label text="Optimisez votre inventaire agricole" styleClass="status-label"/>
        </VBox>
        <HBox HBox.hgrow="ALWAYS"/>
        <TextField fx:id="txtSearch" promptText="Rechercher une ressource..." prefWidth="250" styleClass="search-field"/>
        <ComboBox fx:id="cbSort" promptText="Trier par..." prefWidth="150" styleClass="sort-combo"/>
        <Button text="Nouvelle Ressource" onAction="#openAddModal" styleClass="btn-primary"/>
    </HBox>

    <VBox spacing="15" VBox.vgrow="ALWAYS" styleClass="panel-card">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Liste de l'inventaire" styleClass="panel-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Exporter (Excel)" onAction="#exportExcel" styleClass="btn-primary" style="-fx-font-size: 11px;"/>
        </HBox>
        
        <TableView fx:id="tvRessources" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colNom" text="Nom" prefWidth="200"/>
                <TableColumn fx:id="colType" text="Type" prefWidth="150"/>
                <TableColumn fx:id="colStock" text="Stock Restant" prefWidth="120"/>
                <TableColumn fx:id="colUnite" text="Unité" prefWidth="100"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="150"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

        <Pagination fx:id="pagination" pageCount="1" maxPageIndicatorCount="5" VBox.vgrow="NEVER" style="-fx-page-information-visible: false;"/>
    </VBox>
</VBox>
