<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.MainController"
            styleClass="root-pane">

    <top>
        <VBox styleClass="app-header-wrap" spacing="10">
            <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>

            <HBox spacing="14" alignment="CENTER_LEFT" styleClass="app-header-top">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <StackPane styleClass="logo-mark">
                        <ImageView fitHeight="36" fitWidth="36" preserveRatio="true">
                            <image>
                                <Image url="@../images/logo.png" />
                            </image>
                        </ImageView>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="AgriSmart" styleClass="logo-text"/>
                        <Label text="Smart agriculture operations workspace" styleClass="logo-subtext"/>
                    </VBox>
                </HBox>

                <HBox HBox.hgrow="ALWAYS"/>

                <TextField fx:id="globalSearchField" promptText="Search module, order, product..." onKeyReleased="#handleGlobalSearch" prefWidth="280"/>
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="user-profile-header">
                    <Label fx:id="userNameLabel" text="User Name" styleClass="user-name-text"/>
                    <Label fx:id="userRoleBadge" text="Role" styleClass="role-badge"/>
                </HBox>
                <Button text="Notifications" styleClass="header-icon-btn" onAction="#showNotifications"/>
                <Button text="Profile"      styleClass="header-icon-btn" onAction="#showProfile"/>
                <Button text="Déconnexion"  styleClass="header-icon-btn" onAction="#handleLogout"
                        style="-fx-text-fill: #e74c3c;"/>            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="module-pill-row">
                <Label text="Modules" styleClass="module-label"/>
                <Button fx:id="btnMarketplace" text="Marketplace" styleClass="module-pill" onAction="#openMarketplace"/>
                <Button fx:id="btnCulture" text="Gestion Culture" styleClass="module-pill" onAction="#openCulture"/>
                <Button fx:id="btnRessource" text="Gestion Ressource" styleClass="module-pill" onAction="#openResources"/>
                <Button fx:id="btnTaches" text="Gestion Taches" styleClass="module-pill" onAction="#openTaches"/>
                <Button fx:id="btnEmployes" text="Candidatures" styleClass="module-pill" onAction="#openEmployes"/>
                <Button fx:id="btnUsers" text="Utilisateurs" styleClass="module-pill" onAction="#openUsers"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <StackPane alignment="CENTER_RIGHT">
                    <Label fx:id="currentModuleLabel" text="Current: Marketplace" styleClass="current-module-label"/>
                    <HBox fx:id="headerAlertBox" alignment="CENTER_LEFT" spacing="6" managed="false" visible="false"
                          styleClass="header-alert-box,header-alert-success">
                        <Label fx:id="headerAlertLabel" text="Operation terminee" styleClass="header-alert-label"/>
                    </HBox>
                </StackPane>
            </HBox>
        </VBox>
    </top>


    <center>
        <StackPane styleClass="content-stage">
            <StackPane fx:id="contentArea" styleClass="content-area" BorderPane.alignment="CENTER"/>
        </StackPane>
    </center>

    <bottom>
        <HBox styleClass="app-footer" alignment="CENTER_LEFT">
            <padding><Insets top="8" right="14" bottom="8" left="14"/></padding>
            <Label text="AgriSmart Platform" styleClass="footer-version"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="footerStatusLabel" text="Ready" styleClass="footer-status"/>
        </HBox>
    </bottom>

</BorderPane>
