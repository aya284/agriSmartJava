<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox spacing="20.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.CandidateManagementController">
    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>

    <HBox spacing="25.0" VBox.vgrow="ALWAYS">
        <VBox spacing="20.0" prefWidth="350.0" style="-fx-background-color: #1a3323; -fx-background-radius: 15; -fx-padding: 30;" alignment="TOP_CENTER">
            <Label fx:id="idL" text="ID: #0" style="-fx-text-fill: rgba(255,255,255,0.6);" />
            <Label fx:id="candidateName" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;" text="Nom Prénom" />
            <Label fx:id="phoneL" style="-fx-text-fill: white;" text="📞 +216 ..." />

            <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">
                <Label text="Mettre à jour le statut" style="-fx-font-weight: bold;" />
                <HBox spacing="10.0">
                    <ComboBox fx:id="statusCombo" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    <Button onAction="#handleStatusUpdate" style="-fx-background-color: #1a3323; -fx-text-fill: white;" text="Valider" />
                </HBox>
            </VBox>
        </VBox>

        <VBox spacing="20.0" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
            <Label text="📁 Documents joints" style="-fx-font-size: 20; -fx-font-weight: bold;" />

            <HBox spacing="15.0" alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-border-color: #eee; -fx-border-radius: 10;">
                <Label text="PDF" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 5;" />
                <VBox>
                    <Label text="Curriculum Vitae (CV)" style="-fx-font-weight: bold;" />
                    <Label text="Document PDF" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11;" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#openCV" text="👁 Consulter" style="-fx-background-color: transparent; -fx-border-color: #dee2e6; -fx-border-radius: 5;" />
            </HBox>

            <HBox spacing="15.0" alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-border-color: #eee; -fx-border-radius: 10;">
                <Label text="DOC" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 5;" />
                <VBox>
                    <Label text="Lettre de Motivation" style="-fx-font-weight: bold;" />
                    <Label text="Document PDF / Texte" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11;" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#openLettre" text="👁 Consulter" style="-fx-background-color: transparent; -fx-border-color: #dee2e6; -fx-border-radius: 5;" />
            </HBox>
        </VBox>
    </HBox>
</VBox>