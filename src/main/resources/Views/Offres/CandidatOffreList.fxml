<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.CandidatOffreController"
           style="-fx-background-color: #f4f7f6;">

    <VBox spacing="20.0">
        <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="20.0"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="20.0"
              style="-fx-background-color: white; -fx-padding: 25;
                     -fx-background-radius: 15;
                     -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.05),10,0,0,0);">
            <VBox HBox.hgrow="ALWAYS" spacing="5">
                <Label text="RECHERCHE"
                       style="-fx-font-weight: bold; -fx-text-fill: #95a5a6; -fx-font-size: 11;"/>
                <TextField fx:id="searchField"
                           onKeyReleased="#handleSearch"
                           prefHeight="45.0"
                           promptText="Titre, lieu..."
                           style="-fx-background-radius: 10; -fx-border-color: #ddd;
                                  -fx-border-radius: 10;"/>
            </VBox>
            <VBox prefWidth="250.0" spacing="5">
                <Label text="STATUT"
                       style="-fx-font-weight: bold; -fx-text-fill: #95a5a6; -fx-font-size: 11;"/>
                <ComboBox fx:id="statutFilter"
                          maxWidth="Infinity"
                          prefHeight="45.0"
                          promptText="Toutes les offres"
                          style="-fx-background-radius: 10; -fx-border-color: #ddd;
                                 -fx-border-radius: 10;"/>
            </VBox>
            <Button onAction="#handleSearch"
                    prefHeight="45.0" prefWidth="150.0"
                    style="-fx-background-color: #1a3323; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 10;"
                    text="Rechercher"/>
        </HBox>

        <Label fx:id="countLabel"
               text="0 offre(s) disponible(s)"
               style="-fx-text-fill: #7f8c8d; -fx-font-size: 13;"/>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <FlowPane fx:id="cardsContainer" hgap="25.0" vgap="25.0">
                <padding>
                    <Insets bottom="10.0" left="5.0" right="5.0" top="10.0"/>
                </padding>
            </FlowPane>
        </ScrollPane>
    </VBox>

    <StackPane alignment="BOTTOM_RIGHT" pickOnBounds="false">
        <padding>
            <Insets bottom="20.0" right="20.0"/>
        </padding>

        <VBox alignment="BOTTOM_RIGHT" spacing="8" pickOnBounds="false">

            <VBox fx:id="chatContainer"
                  visible="false"
                  managed="false"
                  prefWidth="300.0"
                  prefHeight="380.0"
                  maxWidth="300.0"
                  maxHeight="380.0"
                  spacing="0"
                  style="-fx-background-color: white;
                         -fx-border-color: #1a3323;
                         -fx-border-radius: 12;
                         -fx-background-radius: 12;
                         -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.25),15,0,0,0);">

                <HBox alignment="CENTER_LEFT"
                      style="-fx-background-color: #1a3323; -fx-padding: 10 15;
                             -fx-background-radius: 12 12 0 0;">
                    <Label text="Assistant AgriSmart"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12;"/>
                </HBox>

                <ScrollPane fx:id="chatScrollPane"
                            fitToWidth="true"
                            VBox.vgrow="ALWAYS"
                            prefHeight="280.0"
                            style="-fx-background-color: #f9f9f9;
                                   -fx-background: #f9f9f9;
                                   -fx-border-color: transparent;">
                    <VBox fx:id="chatMessagesArea" spacing="8">
                        <padding>
                            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                        </padding>
                    </VBox>
                </ScrollPane>

                <HBox spacing="6" alignment="CENTER_LEFT"
                      style="-fx-padding: 8 10;
                             -fx-background-color: white;
                             -fx-border-color: #eeeeee;
                             -fx-border-width: 1 0 0 0;
                             -fx-background-radius: 0 0 12 12;">

                    <Button onAction="#handleUploadCV"
                            text="📁"
                            style="-fx-background-color: #f0f0f0;
                                   -fx-background-radius: 20;
                                   -fx-cursor: hand;
                                   -fx-font-size: 14;"/>

                    <TextField fx:id="chatInputField"
                               HBox.hgrow="ALWAYS"
                               onAction="#handleSendChat"
                               promptText="Posez votre question..."
                               style="-fx-background-radius: 20;
                                      -fx-border-radius: 20;
                                      -fx-border-color: #dddddd;
                                      -fx-padding: 6 12;
                                      -fx-font-size: 12;"/>
                    <Button text="&gt;" onAction="#handleSendChat"
                            style="-fx-background-color: #1a3323;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 20;
                                   -fx-padding: 6 12;
                                   -fx-cursor: hand;
                                   -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

            <Button text="Chat" onAction="#toggleChat"
                    style="-fx-background-color: #1a3323;
                           -fx-text-fill: white;
                           -fx-background-radius: 50;
                           -fx-min-width: 55;
                           -fx-min-height: 55;
                           -fx-max-width: 55;
                           -fx-max-height: 55;
                           -fx-font-size: 13;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.3),10,0,0,0);">
                <VBox.margin>
                    <Insets left="245.0"/>
                </VBox.margin>
            </Button>

        </VBox>
    </StackPane>

</StackPane>