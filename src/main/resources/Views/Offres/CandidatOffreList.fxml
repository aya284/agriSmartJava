<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.CandidatOffreController">
    <padding>
        <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);">
        <VBox HBox.hgrow="ALWAYS" spacing="5">
            <Label text="RECHERCHE" style="-fx-font-weight: bold; -fx-text-fill: #95a5a6; -fx-font-size: 11;" />
            <TextField fx:id="searchField" onKeyReleased="#handleSearch" prefHeight="45.0" promptText="Titre, lieu..." style="-fx-background-radius: 10; -fx-border-color: #ddd; -fx-border-radius: 10;" />
        </VBox>

        <VBox prefWidth="250.0" spacing="5">
            <Label text="STATUT" style="-fx-font-weight: bold; -fx-text-fill: #95a5a6; -fx-font-size: 11;" />
            <ComboBox fx:id="statutFilter" maxWidth="Infinity" prefHeight="45.0" promptText="Toutes les offres" style="-fx-background-radius: 10; -fx-border-color: #ddd; -fx-border-radius: 10;" />
        </VBox>

        <Button onAction="#handleSearch" prefHeight="45.0" prefWidth="150.0" style="-fx-background-color: #1a3323; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="🔍 Rechercher" />
    </HBox>

    <Label fx:id="countLabel" text="0 offre(s) disponible(s)" style="-fx-text-fill: #7f8c8d; -fx-font-size: 13;" />

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
        <FlowPane fx:id="cardsContainer" hgap="25.0" vgap="25.0">
            <padding>
                <Insets bottom="10.0" left="5.0" right="5.0" top="10.0" />
            </padding>
        </FlowPane>
    </ScrollPane>
</VBox>