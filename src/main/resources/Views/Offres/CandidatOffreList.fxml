<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.CandidatOffreController"
           style="-fx-background-color:#f4f7f6;">

    <VBox spacing="15.0">
        <padding><Insets bottom="15.0" left="30.0" right="30.0" top="15.0"/></padding>

        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="15.0"
              style="-fx-background-color:#1a7a43;-fx-background-radius:12;-fx-padding:10 20;">
            <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" spacing="3">
                <Label text="Entrainement Vocal IA"
                       style="-fx-text-fill:white;-fx-font-size:16;-fx-font-weight:bold;"/>
                <Label text="Ameliorez votre score en pratiquant un entretien avec notre IA."
                       style="-fx-text-fill:white;-fx-font-size:12;-fx-opacity:0.9;"/>
            </VBox>
            <Button onAction="#handleLancerTest" text="Lancer le test"
                    style="-fx-background-color:white;-fx-text-fill:#1a7a43;
                           -fx-font-weight:bold;-fx-background-radius:20;
                           -fx-padding:6 18;-fx-cursor:hand;-fx-font-size:12;"/>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="15.0"
              style="-fx-background-color:white;-fx-padding:18 20;-fx-background-radius:12;
                     -fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.05),8,0,0,2);">

            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label text="RECHERCHE" style="-fx-font-weight:bold;-fx-text-fill:#95a5a6;-fx-font-size:10;"/>
                <TextField fx:id="searchField" onKeyReleased="#handleSearch"
                           prefHeight="38.0" promptText="Titre, lieu..."
                           style="-fx-background-radius:8;-fx-border-color:#ddd;-fx-border-radius:8;-fx-padding:0 10;-fx-font-size:13;"/>
            </VBox>

            <VBox prefWidth="200.0" spacing="4">
                <Label text="STATUT" style="-fx-font-weight:bold;-fx-text-fill:#95a5a6;-fx-font-size:10;"/>
                <ComboBox fx:id="statutFilter" maxWidth="Infinity" prefHeight="38.0"
                          promptText="Toutes les offres"
                          style="-fx-background-radius:8;-fx-border-color:#ddd;-fx-border-radius:8;"/>
            </VBox>

            <Button onAction="#handleSearch" text="Rechercher"
                    prefHeight="38.0" prefWidth="120.0"
                    style="-fx-background-color:#1a3323;-fx-text-fill:white;-fx-font-weight:bold;-fx-background-radius:8;-fx-cursor:hand;"/>

            <Button onAction="#handleShowNews" text="📰 News"
                    prefHeight="38.0" prefWidth="100.0"
                    style="-fx-background-color:#1a7a43;-fx-text-fill:white;-fx-font-weight:bold;-fx-background-radius:8;-fx-cursor:hand;"/>
        </HBox>

        <Label fx:id="countLabel" text="Chargement..."
               style="-fx-text-fill:#7f8c8d;-fx-font-size:12;"/>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color:transparent;-fx-background:transparent;-fx-border-color:transparent;">
            <FlowPane fx:id="cardsContainer" hgap="20.0" vgap="20.0">
                <padding><Insets bottom="10.0" left="5.0" right="5.0" top="10.0"/></padding>
            </FlowPane>
        </ScrollPane>
    </VBox>

    <Region fx:id="overlay" visible="false"
            style="-fx-background-color:rgba(0,0,0,0.65);" mouseTransparent="false"/>

    <VBox fx:id="simulatorModal" visible="false"
          maxWidth="560.0" maxHeight="560.0" alignment="TOP_CENTER" spacing="0"
          style="-fx-background-color:white;-fx-background-radius:20;
                 -fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.35),25,0,0,0);">
        <HBox alignment="TOP_RIGHT" style="-fx-padding:12 12 0 12;">
            <Button text="X" onAction="#closeSimulator"
                    style="-fx-background-color:transparent;-fx-font-size:16;-fx-cursor:hand;-fx-text-fill:#7f8c8d;"/>
        </HBox>
        <VBox fx:id="simulatorIntroPane" alignment="CENTER" spacing="18" VBox.vgrow="ALWAYS">
            <Label fx:id="simulatorMainText" text="Simulateur d Entretien"
                   wrapText="true" textAlignment="CENTER"
                   style="-fx-font-size:20;-fx-font-weight:bold;-fx-text-fill:#1a3323;-fx-padding:0 40 0 40;"/>
            <Label fx:id="simulatorSubText" text="Entrainement general pour tous les metiers agricoles."
                   wrapText="true" textAlignment="CENTER"
                   style="-fx-font-size:13;-fx-text-fill:#95a5a6;-fx-padding:0 40 0 40;"/>
            <HBox fx:id="listeningStatus" visible="false" managed="false" alignment="CENTER" spacing="8">
                <Label text="L IA vous ecoute..." style="-fx-font-size:12;-fx-text-fill:#95a5a6;"/>
            </HBox>
            <HBox fx:id="micIndicator" visible="false" managed="false" alignment="CENTER" spacing="8">
                <Label fx:id="micDot" text="●" style="-fx-font-size:14;-fx-text-fill:#e74c3c;"/>
                <Label text="IA en ecoute..." style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#e74c3c;"/>
            </HBox>
            <Button fx:id="btnLancerEntrainement" text="Lancer l entrainement" onAction="#startSimulation"
                    style="-fx-background-color:#1a7a43;-fx-text-fill:white;-fx-font-weight:bold;
                           -fx-font-size:14;-fx-background-radius:30;-fx-padding:12 40;-fx-cursor:hand;"/>
            <VBox.margin><Insets bottom="30.0"/></VBox.margin>
        </VBox>
        <VBox fx:id="simulatorBilanPane" visible="false" managed="false"
              alignment="TOP_CENTER" spacing="0" VBox.vgrow="ALWAYS">
            <ScrollPane fx:id="bilanScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color:transparent;-fx-background:transparent;-fx-border-color:transparent;">
                <VBox fx:id="bilanContent" spacing="12" alignment="TOP_CENTER">
                    <padding><Insets top="5" right="20" bottom="10" left="20"/></padding>
                </VBox>
            </ScrollPane>
            <HBox alignment="CENTER" style="-fx-padding:15 0 20 0;">
                <Button text="Fermer" onAction="#closeSimulator"
                        style="-fx-background-color:#1a3323;-fx-text-fill:white;-fx-font-weight:bold;
                               -fx-font-size:14;-fx-background-radius:30;-fx-padding:12 50;-fx-cursor:hand;"/>
            </HBox>
        </VBox>
    </VBox>

    <StackPane alignment="BOTTOM_RIGHT" pickOnBounds="false">
        <padding><Insets bottom="20.0" right="20.0"/></padding>
        <VBox alignment="BOTTOM_RIGHT" spacing="10" pickOnBounds="false">
            <VBox fx:id="chatContainer" visible="false" managed="false"
                  prefWidth="355.0" prefHeight="500.0" maxWidth="355.0" maxHeight="500.0"
                  style="-fx-background-color:#f9fafb;-fx-background-radius:20;
                         -fx-effect:dropshadow(three-pass-box,rgba(0,0,0,0.18),20,0,0,6);
                         -fx-border-color:#e2e8e4;-fx-border-radius:20;-fx-border-width:1;">
                <VBox style="-fx-background-color:#1a4331;-fx-background-radius:20 20 0 0;-fx-padding:14 16 10 16;" spacing="4">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <StackPane style="-fx-background-color:#2d6a4f;-fx-background-radius:50;
                                         -fx-min-width:38;-fx-min-height:38;-fx-max-width:38;-fx-max-height:38;">
                            <Label text="AI" style="-fx-text-fill:white;-fx-font-weight:bold;-fx-font-size:13;"/>
                        </StackPane>
                        <VBox HBox.hgrow="ALWAYS" spacing="1">
                            <Label text="Assistant AgriSmart" style="-fx-text-fill:white;-fx-font-weight:bold;-fx-font-size:13;"/>
                            <HBox alignment="CENTER_LEFT" spacing="5">
                                <Label fx:id="chatStatusDot" text="●" style="-fx-text-fill:#52e882;-fx-font-size:8;"/>
                                <Label fx:id="chatStatusLabel" text="En ligne - Pret a vous aider" style="-fx-text-fill:rgba(255,255,255,0.7);-fx-font-size:10;"/>
                            </HBox>
                        </VBox>
                        <Button text="X" onAction="#toggleChat" style="-fx-background-color:rgba(255,255,255,0.15); -fx-text-fill:white;-fx-font-size:11;-fx-cursor:hand;-fx-background-radius:50;-fx-min-width:26;-fx-min-height:26;-fx-max-width:26;-fx-max-height:26;-fx-padding:0;"/>
                    </HBox>
                    <Label text="Conseiller emploi agricole personnalise" style="-fx-text-fill:rgba(255,255,255,0.55);-fx-font-size:10;-fx-padding:0 0 0 48;"/>
                </VBox>
                <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color:#f9fafb;-fx-background:#f9fafb;-fx-border-color:transparent;">
                    <VBox fx:id="chatMessagesArea" spacing="10">
                        <padding><Insets top="14" right="12" bottom="8" left="12"/></padding>
                    </VBox>
                </ScrollPane>
                <HBox fx:id="chipsBox" spacing="6" style="-fx-padding:8 12 4 12;">
                    <Button text="Les offres" onAction="#handleChipOffres" style="-fx-background-color:#e8f5e9;-fx-text-fill:#1a4331; -fx-background-radius:20;-fx-padding:5 12; -fx-cursor:hand;-fx-font-size:11;-fx-border-color:#b7dfbf;-fx-border-radius:20;-fx-border-width:1;"/>
                    <Button text="Analyser mon CV" onAction="#handleUploadCV" style="-fx-background-color:#e8f5e9;-fx-text-fill:#1a4331; -fx-background-radius:20;-fx-padding:5 12; -fx-cursor:hand;-fx-font-size:11;-fx-border-color:#b7dfbf;-fx-border-radius:20;-fx-border-width:1;"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER" style="-fx-padding:8 12 12 12;-fx-border-color:#e8ebe8;-fx-border-width:1 0 0 0; -fx-background-color:white;-fx-background-radius:0 0 20 20;">
                    <TextField fx:id="chatInputField" HBox.hgrow="ALWAYS" onAction="#handleSendChat" promptText="Posez votre question..." style="-fx-background-color:#f3f4f6;-fx-background-radius:22;-fx-border-color:transparent;-fx-padding:9 14;-fx-font-size:12;"/>
                    <Button onAction="#handleSendChat" text="->" style="-fx-background-color:#1a4331;-fx-text-fill:white;-fx-background-radius:50;-fx-cursor:hand;-fx-min-width:38;-fx-min-height:38;"/>
                </HBox>
            </VBox>
            <HBox alignment="CENTER_RIGHT">
                <StackPane>
                    <Button onAction="#toggleChat" text="AI" style="-fx-background-color:#1a4331;-fx-background-radius:50;-fx-min-width:58;-fx-min-height:58;-fx-text-fill:white;-fx-effect:dropshadow(three-pass-box,rgba(26,67,49,0.45),14,0,0,5);"/>
                    <Label text="●" style="-fx-text-fill:#52e882;-fx-font-size:12;" StackPane.alignment="TOP_RIGHT"/>
                </StackPane>
            </HBox>
        </VBox>
    </StackPane>
</StackPane>