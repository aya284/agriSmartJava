<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.CandidatOffreController"
           style="-fx-background-color: #f4f7f6;">

    <VBox spacing="20.0">
        <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="20.0"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="20.0"
              style="-fx-background-color: white; -fx-padding: 25;
                     -fx-background-radius: 15;
                     -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.05),10,0,0,0);">
            <VBox HBox.hgrow="ALWAYS" spacing="5">
                <Label text="RECHERCHE"
                       style="-fx-font-weight: bold; -fx-text-fill: #95a5a6; -fx-font-size: 11;"/>
                <TextField fx:id="searchField"
                           onKeyReleased="#handleSearch"
                           prefHeight="45.0"
                           promptText="Titre, lieu..."
                           style="-fx-background-radius: 10; -fx-border-color: #ddd;
                                  -fx-border-radius: 10;"/>
            </VBox>
            <VBox prefWidth="250.0" spacing="5">
                <Label text="STATUT"
                       style="-fx-font-weight: bold; -fx-text-fill: #95a5a6; -fx-font-size: 11;"/>
                <ComboBox fx:id="statutFilter"
                          maxWidth="Infinity"
                          prefHeight="45.0"
                          promptText="Toutes les offres"
                          style="-fx-background-radius: 10; -fx-border-color: #ddd;
                                 -fx-border-radius: 10;"/>
            </VBox>
            <Button onAction="#handleSearch"
                    prefHeight="45.0" prefWidth="150.0"
                    style="-fx-background-color: #1a3323; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 10;"
                    text="Rechercher"/>
        </HBox>

        <Label fx:id="countLabel"
               text="0 offre(s) disponible(s)"
               style="-fx-text-fill: #7f8c8d; -fx-font-size: 13;"/>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <FlowPane fx:id="cardsContainer" hgap="25.0" vgap="25.0">
                <padding>
                    <Insets bottom="10.0" left="5.0" right="5.0" top="10.0"/>
                </padding>
            </FlowPane>
        </ScrollPane>
    </VBox>

    <StackPane alignment="BOTTOM_RIGHT" pickOnBounds="false">
        <padding>
            <Insets bottom="15.0" right="15.0"/>
        </padding>

        <VBox alignment="BOTTOM_RIGHT" spacing="10" pickOnBounds="false">

            <VBox fx:id="chatContainer"
                  visible="false"
                  managed="false"
                  prefWidth="280.0"
                  prefHeight="350.0"
                  maxWidth="280.0"
                  maxHeight="350.0"
                  style="-fx-background-color: white;
                         -fx-background-radius: 12;
                         -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.15),10,0,0,0);
                         -fx-border-color: #e0e0e0;
                         -fx-border-radius: 12;">

                <HBox alignment="CENTER_LEFT" prefHeight="35.0"
                      style="-fx-background-color: #28a745; -fx-background-radius: 12 12 0 0; -fx-padding: 0 10;">
                    <Label text="🌱 Assistant AgriSmart"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11;"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="✕" onAction="#toggleChat"
                            style="-fx-background-color: transparent; -fx-text-fill: white;
                                   -fx-font-size: 14; -fx-cursor: hand; -fx-padding: 0;"/>
                </HBox>

                <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: white; -fx-background: white; -fx-border-color: transparent;">
                    <VBox fx:id="chatMessagesArea" spacing="8">
                        <padding>
                            <Insets top="10" right="10" bottom="10" left="10"/>
                        </padding>
                    </VBox>
                </ScrollPane>

                <HBox spacing="5" alignment="CENTER"
                      style="-fx-padding: 8; -fx-border-color: #f0f0f0; -fx-border-width: 1 0 0 0;">

                    <Button onAction="#handleUploadCV" text="📎"
                            style="-fx-background-color: transparent; -fx-text-fill: #888888;
                                   -fx-cursor: hand; -fx-font-size: 14;"/>

                    <TextField fx:id="chatInputField" HBox.hgrow="ALWAYS" onAction="#handleSendChat"
                               promptText="Votre message..."
                               style="-fx-background-color: #f8f9fa; -fx-background-radius: 15;
                                      -fx-border-color: transparent; -fx-padding: 5 12; -fx-font-size: 11;"/>

                    <Button onAction="#handleSendChat" text="➤"
                            style="-fx-background-color: #28a745; -fx-text-fill: white;
                                   -fx-background-radius: 50; -fx-cursor: hand;
                                   -fx-min-width: 28; -fx-min-height: 28; -fx-font-size: 10;"/>
                </HBox>
            </VBox>

            <Button onAction="#toggleChat"
                    style="-fx-background-color: #28a745;
                           -fx-background-radius: 50;
                           -fx-min-width: 50; -fx-min-height: 50;
                           -fx-max-width: 50; -fx-max-height: 50;
                           -fx-cursor: hand;
                           -fx-font-size: 18;
                           -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.2),8,0,0,0);"
                    text="🤖">
            </Button>

        </VBox>
    </StackPane>

</StackPane>