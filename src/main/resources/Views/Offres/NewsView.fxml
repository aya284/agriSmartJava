<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #f4f4f4;"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.NewsController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="20">
            <Button text="⬅ Retour aux Offres" onAction="#handleRetour"
                    style="-fx-background-color: #1a3323; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Label text="Actualités Agricoles en Temps Réel"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a3323;" />
        </HBox>

        <ListView fx:id="newsListView" VBox.vgrow="ALWAYS"
                  style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #ddd;" />

        <HBox alignment="CENTER" spacing="10">
            <Label text="Source: NewsAPI.org - Données connectées AgriSmart"
                   style="-fx-font-size: 10; -fx-text-fill: gray;" />
        </HBox>
    </children>
</VBox>