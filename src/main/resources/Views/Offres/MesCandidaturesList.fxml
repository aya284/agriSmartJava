<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MesCandidaturesController">
    <VBox spacing="25.0">
        <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>

        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <VBox>
                <Label text="Mes Candidatures" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1a3323;" />
                <Label text="Suivez l'état de vos demandes d'emploi" style="-fx-text-fill: #7f8c8d;" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#showOffres" style="-fx-background-color: #1a3323; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 5;" text="🔍 Parcourir les offres" />
        </HBox>

        <HBox spacing="20.0">
            <VBox prefWidth="250.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                <Label text="Acceptées" textFill="#7f8c8d" />
                <Label fx:id="statAcceptee" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;" textFill="#27ae60" />
            </VBox>
            <VBox prefWidth="250.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                <Label text="En cours" textFill="#7f8c8d" />
                <Label fx:id="statEnCours" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;" textFill="#f39c12" />
            </VBox>
            <VBox prefWidth="250.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                <Label text="Refusées" textFill="#7f8c8d" />
                <Label fx:id="statRefusee" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;" textFill="#e74c3c" />
            </VBox>
        </HBox>

        <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20;">
            <Label text="📋 Historique des candidatures" style="-fx-font-weight: bold; -fx-font-size: 16;" />
            <VBox fx:id="listContainer" spacing="15" />
        </VBox>
    </VBox>
</ScrollPane>