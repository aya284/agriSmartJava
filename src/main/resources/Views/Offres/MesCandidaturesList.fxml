<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MesCandidaturesController" style="-fx-background-color: #f4f7f6;">

    <VBox spacing="25.0">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <VBox>
                <Label text="Mes Candidatures" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1a3323;" />
                <Label text="Suivez l'état de vos demandes d'emploi" style="-fx-text-fill: #7f8c8d;" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#showOffres" text="🔍 Parcourir les offres"
                    style="-fx-background-color: #1a3323; -fx-text-fill: white; -fx-padding: 10 25; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-weight: bold;" />
        </HBox>

        <HBox spacing="25.0">
            <VBox prefWidth="280.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                <Label text="Acceptées" textFill="#7f8c8d" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
                <Label fx:id="statAcceptee" text="0" style="-fx-font-size: 36; -fx-font-weight: bold;" textFill="#27ae60" />
            </VBox>
            <VBox prefWidth="280.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                <Label text="En cours" textFill="#7f8c8d" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
                <Label fx:id="statEnCours" text="0" style="-fx-font-size: 36; -fx-font-weight: bold;" textFill="#f39c12" />
            </VBox>
            <VBox prefWidth="280.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                <Label text="Refusées" textFill="#7f8c8d" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
                <Label fx:id="statRefusee" text="0" style="-fx-font-size: 36; -fx-font-weight: bold;" textFill="#e74c3c" />
            </VBox>
        </HBox>

        <VBox spacing="15" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
            <Label text="📋 Historique des candidatures" style="-fx-font-weight: bold; -fx-font-size: 18; -fx-text-fill: #1a3323;" />
            <Separator />
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <VBox fx:id="listContainer" spacing="10" style="-fx-background-color: white;" />
            </ScrollPane>
        </VBox>
    </VBox>

    <StackPane alignment="BOTTOM_RIGHT" pickOnBounds="false">
        <padding>
            <Insets bottom="20.0" right="20.0"/>
        </padding>

        <VBox alignment="BOTTOM_RIGHT" spacing="10" pickOnBounds="false">

            <VBox fx:id="chatContainer" visible="false" managed="false"
                  prefWidth="320.0" prefHeight="420.0" maxWidth="320.0" maxHeight="420.0"
                  style="-fx-background-color: white; -fx-background-radius: 15;
                         -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.15),15,0,0,0);
                         -fx-border-color: #e0e0e0; -fx-border-radius: 15;">

                <HBox alignment="CENTER_LEFT" prefHeight="45.0"
                      style="-fx-background-color: #28a745; -fx-background-radius: 15 15 0 0; -fx-padding: 0 15;">
                    <Label text="🌱 Assistant Profil" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="✕" onAction="#toggleChat" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" />
                </HBox>

                <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background: white; -fx-border-color: transparent;">
                    <VBox fx:id="chatMessagesArea" spacing="10" style="-fx-padding: 15;" />
                </ScrollPane>

                <HBox spacing="8" alignment="CENTER" style="-fx-padding: 10; -fx-border-color: #f0f0f0; -fx-border-width: 1 0 0 0;">
                    <TextField fx:id="chatInputField" HBox.hgrow="ALWAYS" onAction="#handleSendChat"
                               promptText="Modifier mon profil..."
                               style="-fx-background-color: #f8f9fa; -fx-background-radius: 20; -fx-padding: 8 15;" />
                    <Button onAction="#handleSendChat" text="➤"
                            style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-background-radius: 50; -fx-min-width: 35; -fx-min-height: 35; -fx-cursor: hand;" />
                </HBox>
            </VBox>

            <Button onAction="#toggleChat"
                    style="-fx-background-color: #28a745; -fx-background-radius: 50; -fx-min-width: 60; -fx-min-height: 60; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.2),10,0,0,0);">
                <graphic>
                    <Label text="🌱" style="-fx-font-size: 24; -fx-text-fill: white;" />
                </graphic>
            </Button>
        </VBox>
    </StackPane>
</StackPane>