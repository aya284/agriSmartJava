<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.OffreController">
    <VBox spacing="25.0">
        <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>

        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <Label text="Mes offres d'emploi" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1a3323;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#showAddPage" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 5;" text="+ Nouvelle offre" />
        </HBox>

        <HBox spacing="20.0">
            <VBox prefWidth="250.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                <Label text="Total" textFill="#7f8c8d" />
                <Label fx:id="statTotalOffres" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;" />
            </VBox>
            <VBox prefWidth="250.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                <Label text="Approuvées" textFill="#7f8c8d" />
                <Label fx:id="statApprouve" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;" textFill="#27ae60" />
            </VBox>
        </HBox>

        <TextField fx:id="searchField" onKeyReleased="#handleSearch" prefHeight="45.0" promptText="Rechercher par titre ou lieu..." style="-fx-background-radius: 5; -fx-border-color: #dee2e6; -fx-border-radius: 5;" />

        <FlowPane fx:id="cardsContainer" hgap="20.0" vgap="20.0" />
    </VBox>
</ScrollPane>