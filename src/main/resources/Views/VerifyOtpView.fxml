<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.user.VerifyOtpController">

    <VBox alignment="CENTER" maxWidth="460" spacing="22"
          style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 50 55 45 55; -fx-border-color: #e5e7eb; -fx-border-width: 1; -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 28, 0.0, 0, 14);">

        <VBox alignment="CENTER" spacing="6">
            <Label text="Verification par Email"
                   style="-fx-text-fill: #2a5438; -fx-font-size: 26px; -fx-font-weight: bold;"/>
            <Label fx:id="emailLabel" text="Un code a ete envoye a votre adresse e-mail."
                   wrapText="true" maxWidth="340"
                   style="-fx-text-fill: #555555; -fx-font-size: 13.5px;"/>
        </VBox>

        <Separator/>

        <VBox spacing="8" maxWidth="340">
            <Label text="Code de verification"
                   style="-fx-text-fill: #2a5438; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            <TextField fx:id="otpField" promptText="000000"
                       style="-fx-background-color: #f8f9fa; -fx-background-radius: 12; -fx-border-color: #d1d5db; -fx-border-width: 1; -fx-padding: 14 16; -fx-font-size: 22px; -fx-alignment: CENTER;"/>
            <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c; -fx-font-size: 13px;" visible="false" wrapText="true"/>
        </VBox>

        <Button text="Verifier et Se Connecter" maxWidth="340" onAction="#handleVerify"
                style="-fx-background-color: #2a5438; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 12; -fx-padding: 14 20; -fx-cursor: hand;"/>

        <VBox alignment="CENTER" spacing="8">
            <HBox alignment="CENTER" spacing="6">
                <Label text="Pas recu le code ?" style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
                <Hyperlink onAction="#handleResend"
                           style="-fx-text-fill: #2a5438; -fx-font-weight: bold; -fx-font-size: 13px;"
                           text="Renvoyer"/>
            </HBox>
            <Hyperlink onAction="#handleBack"
                       style="-fx-text-fill: #E6BF4A; -fx-font-weight: bold; -fx-font-size: 13px;"
                       text="&lt;- Changer de methode"/>
        </VBox>

    </VBox>
</StackPane>
