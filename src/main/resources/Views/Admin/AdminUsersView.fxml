<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="16"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.admin.AdminUsersController">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Gestion des Utilisateurs"
               style="-fx-font-size: 20; -fx-font-weight: bold;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Label fx:id="totalLabel" text="Total : ..."
               style="-fx-text-fill: #777; -fx-font-size: 13;"/>
    </HBox>

    <!-- Filtres -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: white; -fx-padding: 14;
                 -fx-background-radius: 8;
                 -fx-effect: dropshadow(gaussian,#ddd,4,0,0,1);">
        <TextField fx:id="searchField"
                   promptText="🔍  Rechercher par nom ou email..."
                   prefWidth="280"/>
        <Label text="Rôle :"    style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="roleFilter"   prefWidth="140"/>
        <Label text="Statut :"  style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="statusFilter" prefWidth="130"/>
        <Button text="Réinitialiser" onAction="#resetFilters"
                style="-fx-background-color: #ecf0f1;
                       -fx-padding: 6 14; -fx-background-radius: 4;"/>
    </HBox>

    <!-- Tableau -->
    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color: white;
                      -fx-effect: dropshadow(gaussian,#ddd,4,0,0,1);">
        <columns>
            <TableColumn fx:id="colId"      text="ID"          prefWidth="50"/>
            <TableColumn fx:id="colName"    text="Nom complet" prefWidth="170"/>
            <TableColumn fx:id="colEmail"   text="Email"       prefWidth="210"/>
            <TableColumn fx:id="colRole"    text="Rôle"        prefWidth="110"/>
            <TableColumn fx:id="colStatus"  text="Statut"      prefWidth="100"/>
            <TableColumn fx:id="colDate"    text="Inscrit le"  prefWidth="110"/>
            <TableColumn fx:id="colActions" text="Actions"     prefWidth="250"/>
        </columns>
        <placeholder>
            <Label text="Aucun utilisateur trouvé."
                   style="-fx-text-fill: #aaa; -fx-font-size: 14;"/>
        </placeholder>
    </TableView>

</VBox>