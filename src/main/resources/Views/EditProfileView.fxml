<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.user.EditProfileController"
            style="-fx-background-color: transparent;">

    <VBox spacing="24" style="-fx-padding: 30;">

        <Label text="Mon Profil" style="-fx-font-size: 22; -fx-font-weight: bold;"/>

        <!-- ── Section : Informations personnelles ── -->
        <VBox spacing="12" style="-fx-background-color: white;
                                   -fx-padding: 20;
                                   -fx-background-radius: 8;
                                   -fx-effect: dropshadow(gaussian,#ddd,6,0,0,2);">

            <Label text="Informations personnelles"
                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #2ecc71;"/>

            <HBox spacing="12">
                <TextField fx:id="firstNameField" promptText="Prénom *" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="lastNameField"  promptText="Nom *"    HBox.hgrow="ALWAYS"/>
            </HBox>

            <TextField fx:id="emailField"   promptText="Adresse e-mail *"/>
            <TextField fx:id="phoneField"   promptText="Téléphone"/>
            <TextField fx:id="addressField" promptText="Adresse"/>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Rôle : " style="-fx-font-weight: bold;"/>
                <Label fx:id="roleLabel" style="-fx-text-fill: #555;"/>
            </HBox>

            <Label fx:id="infoMessage" visible="false" wrapText="true"
                   style="-fx-font-size: 12;"/>

            <Button fx:id="saveBtn" text="Sauvegarder"
                    onAction="#handleSave"
                    style="-fx-background-color: #2ecc71; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 8 20;"/>
        </VBox>

        <!-- ── Section : Photo de profil ── -->
        <VBox spacing="12" style="-fx-background-color: white;
                                   -fx-padding: 20;
                                   -fx-background-radius: 8;
                                   -fx-effect: dropshadow(gaussian,#ddd,6,0,0,2);">

            <Label text="Photo de profil"
                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #2ecc71;"/>

            <HBox spacing="16" alignment="CENTER_LEFT">
                <ImageView fx:id="profilePreview" fitWidth="80" fitHeight="80"
                           preserveRatio="true"
                           style="-fx-effect: dropshadow(gaussian,#aaa,4,0,0,1);"/>
                <VBox spacing="6">
                    <Button text="📷  Changer la photo" onAction="#handleChooseImage"/>
                    <Label fx:id="imageFileLabel" text="Aucune photo choisie"
                           style="-fx-text-fill: #999; -fx-font-size: 11;"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- ── Section : Document justificatif ── -->
        <VBox spacing="12" style="-fx-background-color: white;
                                   -fx-padding: 20;
                                   -fx-background-radius: 8;
                                   -fx-effect: dropshadow(gaussian,#ddd,6,0,0,2);">

            <Label text="Document justificatif"
                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #2ecc71;"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="📎  Changer le document" onAction="#handleChooseDocument"/>
                <Label fx:id="documentFileLabel" text="Aucun document choisi"
                       style="-fx-text-fill: #999; -fx-font-size: 11;"/>
            </HBox>
        </VBox>

        <!-- ── Section : Changer mot de passe ── -->
        <VBox spacing="12" style="-fx-background-color: white;
                                   -fx-padding: 20;
                                   -fx-background-radius: 8;
                                   -fx-effect: dropshadow(gaussian,#ddd,6,0,0,2);">

            <Label text="Changer le mot de passe"
                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #2ecc71;"/>

            <PasswordField fx:id="currentPasswordField"    promptText="Mot de passe actuel"/>
            <PasswordField fx:id="newPasswordField"        promptText="Nouveau mot de passe"/>
            <PasswordField fx:id="confirmNewPasswordField" promptText="Confirmer le nouveau mot de passe"/>

            <Label fx:id="passwordMessage" visible="false" wrapText="true"
                   style="-fx-font-size: 12;"/>

            <Button fx:id="changePasswordBtn" text="Modifier le mot de passe"
                    onAction="#handleChangePassword"
                    style="-fx-background-color: #3498db; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 8 20;"/>
        </VBox>

    </VBox>
</ScrollPane>