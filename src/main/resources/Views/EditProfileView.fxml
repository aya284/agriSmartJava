<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.user.EditProfileController"
            styleClass="edit-profile-scroll">

    <VBox spacing="24" styleClass="edit-profile-root" stylesheets="@../css/edit-profile.css">

        <!-- HEADER -->
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="profile-header-card">

            <ImageView fx:id="profilePreview"
                       fitWidth="90" fitHeight="90"
                       styleClass="profile-avatar"/>

            <VBox spacing="6">
                <Label fx:id="fullNameLabel" styleClass="profile-name"/>
                <Label fx:id="roleLabel" styleClass="profile-role"/>
                <Label text="Photo visible par les autres utilisateurs" styleClass="hint"/>
                <Button text="Changer photo"
                        onAction="#handleChooseImage"
                        styleClass="btn-outline"/>
            </VBox>

        </HBox>

        <!-- MAIN -->
        <HBox spacing="20">

            <!-- LEFT -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">

                <!-- ACCOUNT -->
                <VBox spacing="12" styleClass="card">
                    <Label text="Informations du compte" styleClass="section-title"/>
                    <Label text="Ces informations seront visibles dans votre profil."
                           styleClass="hint"/>

                    <VBox spacing="6">
                        <Label text="Prénom"/>
                        <TextField fx:id="firstNameField" promptText="Ex: Sarah" styleClass="field"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Nom"/>
                        <TextField fx:id="lastNameField" promptText="Ex: Ben Ali" styleClass="field"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Adresse e-mail"/>
                        <TextField fx:id="emailField" promptText="example@email.com" styleClass="field"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Téléphone"/>
                        <TextField fx:id="phoneField" promptText="+216 ..." styleClass="field"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Adresse"/>
                        <TextField fx:id="addressField" promptText="Votre adresse" styleClass="field"/>
                    </VBox>

                    <Label fx:id="infoMessage" visible="false"/>

                    <Button fx:id="saveBtn"
                            text="Enregistrer"
                            onAction="#handleSave"
                            styleClass="btn-primary"/>
                </VBox>

                <!-- SECURITY -->
                <VBox spacing="12" styleClass="card">
                    <Label text="Sécurité" styleClass="section-title"/>
                    <Label text="Choisissez un mot de passe fort pour protéger votre compte."
                           styleClass="hint"/>

                    <VBox spacing="6">
                        <Label text="Mot de passe actuel"/>
                        <PasswordField fx:id="currentPasswordField" styleClass="field"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Nouveau mot de passe"/>
                        <PasswordField fx:id="newPasswordField" styleClass="field"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Confirmer le mot de passe"/>
                        <PasswordField fx:id="confirmNewPasswordField" styleClass="field"/>
                    </VBox>

                    <Label fx:id="passwordMessage" visible="false"/>

                    <Button fx:id="changePasswordBtn"
                            text="Mettre à jour"
                            onAction="#handleChangePassword"
                            styleClass="btn-primary"/>
                </VBox>

            </VBox>

            <!-- RIGHT -->
            <VBox spacing="20" prefWidth="300">

                <!-- DOCUMENT -->
                <VBox spacing="12" styleClass="card">
                    <Label text="Documents" styleClass="section-title"/>
                    <Label text="Ajoutez un document pour vérification."
                           styleClass="hint"/>

                    <Button text="Uploader document"
                            onAction="#handleChooseDocument"
                            styleClass="btn-outline"/>

                    <Label fx:id="documentFileLabel" text="Aucun fichier"/>
                </VBox>

                <!-- ACCOUNT INFO -->
                <VBox spacing="12" styleClass="card">
                    <Label text="Informations" styleClass="section-title"/>
                    <Label text="Votre rôle ne peut pas être modifié."
                           wrapText="true"
                           styleClass="hint"/>
                </VBox>

                <!-- DANGER -->
                <VBox spacing="12" styleClass="danger-card">
                    <Label text="Zone dangereuse" styleClass="danger-title"/>
                    <Label text="Action irréversible." styleClass="hint"/>

                    <PasswordField fx:id="deletePasswordField"
                                   promptText="Mot de passe"
                                   styleClass="field"/>

                    <Label fx:id="deleteMessage" visible="false"/>

                    <Button fx:id="deleteAccountBtn"
                            text="Supprimer compte"
                            onAction="#handleDeleteAccount"
                            styleClass="btn-danger"/>
                </VBox>

            </VBox>

        </HBox>

    </VBox>
</ScrollPane>