<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.FrontController"
            styleClass="root-pane">

    <top>
        <VBox styleClass="app-header-wrap" spacing="10">
            <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>

            <HBox spacing="14" alignment="CENTER_LEFT" styleClass="app-header-top">
                <VBox spacing="2">
                    <Label text="AgriSmart" styleClass="logo-text" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
                    <Label text="Espace Candidat" styleClass="logo-subtext" style="-fx-text-fill: #27ae60;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Déconnexion" styleClass="header-icon-btn" onAction="#handleLogout" style="-fx-text-fill: #e74c3c;"/>
                <Button text="Mon Profil" styleClass="header-icon-btn" />
            </HBox>

            <HBox spacing="15" alignment="CENTER_LEFT" styleClass="module-pill-row">
                <Button text="Marketplace"
                        styleClass="module-pill"
                        onAction="#openMarketplace"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;"/>

                <Button text="Offres d'emploi"
                        styleClass="module-pill"
                        onAction="#openCandidatures"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;"/>

                <Button text="Mes candidatures"
                        styleClass="module-pill"
                        onAction="#openMesCandidatures"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area" BorderPane.alignment="CENTER">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
        </StackPane>
    </center>

    <bottom>
        <HBox styleClass="app-footer" alignment="CENTER_LEFT" style="-fx-background-color: #eee;">
            <padding><Insets top="8" right="14" bottom="8" left="14"/></padding>
            <Label text="AgriSmart - Portail Candidat" styleClass="footer-version"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="footerStatusLabel" text="Prêt" styleClass="footer-status"/>
        </HBox>
    </bottom>

</BorderPane>