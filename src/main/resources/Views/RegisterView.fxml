<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.user.RegisterController">

    <HBox alignment="CENTER" maxHeight="620" maxWidth="980" spacing="0">

        <!-- LEFT SIDE: Branding & Benefits -->
        <VBox alignment="CENTER" prefWidth="380" spacing="30" style="-fx-background-color: #2a5438;                      -fx-padding: 60 40 60 40;                      -fx-background-radius: 20 0 0 20;">

            <VBox alignment="CENTER" spacing="12">
                <Label style="-fx-text-fill: white;                               -fx-font-size: 42px;                               -fx-font-weight: bold;" text="AgriSmart" />
                <Label style="-fx-text-fill: #a8d5b8;                               -fx-font-size: 18px;" text="L'agriculture intelligente" />
            </VBox>

            <ImageView fx:id="logoImage" fitHeight="140" fitWidth="140" preserveRatio="true">
            <image>
               <Image url="@../images/logo.png" />
            </image></ImageView>

            <VBox alignment="CENTER_LEFT" maxWidth="280" spacing="18">
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <Label style="-fx-font-size: 24px;" text="🌱" />
                    <VBox spacing="2">
                        <Label style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;" text="Gestion intelligente" />
                        <Label style="-fx-text-fill: #a8d5b8; -fx-font-size: 13px;" text="Suivez vos cultures en temps réel" />
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="14">
                    <Label style="-fx-font-size: 24px;" text="📊" />
                    <VBox spacing="2">
                        <Label style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;" text="Analyses précises" />
                        <Label style="-fx-text-fill: #a8d5b8; -fx-font-size: 13px;" text="Rapports et prévisions détaillés" />
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="14">
                    <Label style="-fx-font-size: 24px;" text="🤝" />
                    <VBox spacing="2">
                        <Label style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;" text="Communauté agricole" />
                        <Label style="-fx-text-fill: #a8d5b8; -fx-font-size: 13px;" text="Partagez et apprenez avec d'autres agriculteurs" />
                    </VBox>
                </HBox>
            </VBox>

            <Label style="-fx-text-fill: #a8d5b8; -fx-font-size: 14px;" text="Déjà inscrit ?" />
            <Hyperlink onAction="#goToLogin" style="-fx-text-fill: #E6BF4A;                               -fx-font-size: 16px;                               -fx-font-weight: bold;" text="Se connecter" />
        </VBox>

        <!-- RIGHT SIDE: Registration Form -->
        <ScrollPane fitToWidth="true" prefWidth="600" style="-fx-background-color: transparent;                            -fx-background-insets: 0;">

            <VBox alignment="TOP_CENTER" spacing="35" style="-fx-padding: 60 70 60 70;                          -fx-background-color: white;                          -fx-background-radius: 0 20 20 0;">

                <!-- Form Header -->
                <VBox alignment="CENTER" spacing="8">
                    <Label style="-fx-font-size: 30px;                                   -fx-font-weight: bold;                                   -fx-text-fill: #2a5438;" text="Créer un compte" />
                    <Label style="-fx-text-fill: #666666;                                   -fx-font-size: 15px;" text="Rejoignez AgriSmart dès aujourd'hui" />
                </VBox>

                <!-- Form Fields -->
                <VBox maxWidth="460" spacing="20">

                    <!-- Name Row -->
                    <HBox spacing="16">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #2a5438; -fx-font-size: 13.5px;" text="Prénom *" />
                            <TextField fx:id="firstNameField" promptText="Votre prénom" style="-fx-background-radius: 12; -fx-padding: 13 16; -fx-font-size: 15px;" />
                            <Label fx:id="errFirstName" style="-fx-text-fill:#e74c3c; -fx-font-size:12px;" visible="false" />
                        </VBox>

                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #2a5438; -fx-font-size: 13.5px;" text="Nom *" />
                            <TextField fx:id="lastNameField" promptText="Votre nom" style="-fx-background-radius: 12; -fx-padding: 13 16; -fx-font-size: 15px;" />
                            <Label fx:id="errLastName" style="-fx-text-fill:#e74c3c; -fx-font-size:12px;" visible="false" />
                        </VBox>
                    </HBox>

                    <!-- Email -->
                    <VBox spacing="6">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2a5438; -fx-font-size: 13.5px;" text="Adresse e-mail *" />
                        <TextField fx:id="emailField" promptText="exemple@domaine.com" style="-fx-background-radius: 12; -fx-padding: 13 16; -fx-font-size: 15px;" />
                        <Label fx:id="errEmail" style="-fx-text-fill:#e74c3c; -fx-font-size:12px;" visible="false" />
                    </VBox>

                    <!-- Role -->
                    <VBox spacing="6">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2a5438; -fx-font-size: 13.5px;" text="Type de compte *" />
                        <ComboBox fx:id="roleComboBox" maxWidth="Infinity" promptText="Sélectionnez votre rôle" style="-fx-background-radius: 12; -fx-padding: 8;" />
                        <Label fx:id="errRole" style="-fx-text-fill:#e74c3c; -fx-font-size:12px;" visible="false" />
                    </VBox>

                    <!-- Passwords -->
                    <HBox spacing="16">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #2a5438; -fx-font-size: 13.5px;" text="Mot de passe *" />
                            <PasswordField fx:id="passwordField" promptText="Mot de passe" style="-fx-background-radius: 12; -fx-padding: 13 16; -fx-font-size: 15px;" />
                            <Label fx:id="errPassword" style="-fx-text-fill:#e74c3c; -fx-font-size:12px;" visible="false" />
                        </VBox>

                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #2a5438; -fx-font-size: 13.5px;" text="Confirmation *" />
                            <PasswordField fx:id="confirmPasswordField" promptText="Confirmer" style="-fx-background-radius: 12; -fx-padding: 13 16; -fx-font-size: 15px;" />
                            <Label fx:id="errConfirm" style="-fx-text-fill:#e74c3c; -fx-font-size:12px;" visible="false" />
                        </VBox>
                    </HBox>

                    <!-- Phone + Address (smaller fields) -->
                    <HBox spacing="16">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #2a5438; -fx-font-size: 13.5px;" text="Téléphone" />
                            <TextField fx:id="phoneField" promptText="22123456" style="-fx-background-radius: 12; -fx-padding: 13 16; -fx-font-size: 15px;" />
                            <Label fx:id="errPhone" style="-fx-text-fill:#e74c3c; -fx-font-size:12px;" visible="false" />
                        </VBox>

                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #2a5438; -fx-font-size: 13.5px;" text="Adresse" />
                            <TextField fx:id="addressField" promptText="Votre adresse" style="-fx-background-radius: 12; -fx-padding: 13 16; -fx-font-size: 15px;" />
                            <Label fx:id="errAddress" style="-fx-text-fill:#e74c3c; -fx-font-size:12px;" visible="false" />
                        </VBox>
                    </HBox>

                    <Separator />

                    <!-- Profile Picture -->
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <ImageView fx:id="profilePreview" fitHeight="82" fitWidth="82" preserveRatio="true" style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 10, 0, 0, 3);                                           -fx-border-radius: 12;" />

                        <VBox spacing="12">
                            <Button onAction="#handleChooseImage" style="-fx-background-color: white;                                            -fx-border-color: #d1d5db;                                            -fx-border-radius: 10;                                            -fx-padding: 10 20;" text="📷 Choisir une photo de profil" />
                            <Label fx:id="imageFileLabel" style="-fx-text-fill:#999; -fx-font-size:12.5px;" text="Aucun fichier choisi" />
                            <Label fx:id="errImage" style="-fx-text-fill:#e74c3c; -fx-font-size:12px;" visible="false" />
                        </VBox>
                    </HBox>

                    <!-- Document -->
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <Button onAction="#handleChooseDocument" style="-fx-background-color: white;                                        -fx-border-color: #d1d5db;                                        -fx-border-radius: 10;                                        -fx-padding: 10 20;" text="📎 Choisir un document justificatif" />
                        <VBox spacing="6">
                            <Label fx:id="documentFileLabel" style="-fx-text-fill:#999; -fx-font-size:12.5px;" text="Aucun fichier choisi" />
                            <Label fx:id="errDocument" style="-fx-text-fill:#e74c3c; -fx-font-size:12px;" visible="false" />
                        </VBox>
                    </HBox>

                    <!-- Success Message -->
                    <Label fx:id="successLabel" style="-fx-text-fill: #27ae60; -fx-font-weight: bold; -fx-font-size: 14px;" visible="false" wrapText="true" />

                    <!-- Register Button -->
                    <Button fx:id="registerBtn" maxWidth="Infinity" onAction="#handleRegister" style="-fx-background-color: #2a5438;                                    -fx-text-fill: white;                                    -fx-font-size: 16px;                                    -fx-font-weight: bold;                                    -fx-background-radius: 12;                                    -fx-padding: 15 20;" text="Créer mon compte" />

                </VBox>
            </VBox>
        </ScrollPane>
    </HBox>
</StackPane>
