<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.RegisterController"
            style="-fx-background-color: #f4f6f8;">

    <VBox alignment="TOP_CENTER" spacing="20" style="-fx-padding: 40;">

        <Label text="Créer un compte" style="-fx-font-size: 26; -fx-font-weight: bold;"/>
        <Label text="Rejoignez AgriSmart" style="-fx-text-fill: #777;"/>

        <VBox maxWidth="480" spacing="12">

            <!-- Nom & Prénom -->
            <HBox spacing="10">
                <TextField fx:id="firstNameField" promptText="Prénom *" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="lastNameField"  promptText="Nom *"    HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Email -->
            <TextField fx:id="emailField" promptText="Adresse e-mail *"/>

            <!-- Rôle -->
            <ComboBox fx:id="roleComboBox" promptText="Type de compte *" maxWidth="Infinity"/>

            <!-- Mot de passe -->
            <PasswordField fx:id="passwordField"        promptText="Mot de passe * (8+ cars, A-Z, 0-9, spécial)"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Confirmer le mot de passe *"/>

            <!-- Téléphone -->
            <TextField fx:id="phoneField" promptText="Téléphone (ex: 22123456)"/>

            <!-- Adresse -->
            <TextField fx:id="addressField" promptText="Adresse"/>

            <Separator/>

            <!-- Photo de profil -->
            <Label text="Photo de profil (JPEG / PNG — max 5 Mo)"
                   style="-fx-text-fill: #555; -fx-font-weight: bold;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ImageView fx:id="profilePreview" fitWidth="64" fitHeight="64"
                           preserveRatio="true"
                           style="-fx-background-color:#ddd; -fx-effect: dropshadow(gaussian,#aaa,4,0,0,1);"/>
                <VBox spacing="4">
                    <Button text="📷  Choisir une image" onAction="#handleChooseImage"/>
                    <Label fx:id="imageFileLabel" text="Aucun fichier choisi"
                           style="-fx-text-fill: #999; -fx-font-size: 11;"/>
                </VBox>
            </HBox>

            <!-- Document justificatif -->
            <Label text="Document justificatif (PDF / JPEG / PNG — max 5 Mo)"
                   style="-fx-text-fill: #555; -fx-font-weight: bold;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="📎  Choisir un document" onAction="#handleChooseDocument"/>
                <Label fx:id="documentFileLabel" text="Aucun fichier choisi"
                       style="-fx-text-fill: #999; -fx-font-size: 11;"/>
            </HBox>

            <Separator/>

            <!-- Message d'erreur / succès -->
            <Label fx:id="errorLabel" visible="false" wrapText="true"
                   maxWidth="480" style="-fx-font-size: 12;"/>

            <!-- Bouton inscription -->
            <Button fx:id="registerBtn" text="Créer le compte"
                    onAction="#handleRegister" maxWidth="Infinity"
                    style="-fx-background-color: #2ecc71; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-padding: 10; -fx-font-size: 14;"/>

            <!-- Lien vers login -->
            <HBox alignment="CENTER" spacing="4">
                <Label text="Déjà inscrit ?"/>
                <Hyperlink text="Se connecter" onAction="#goToLogin"/>
            </HBox>

        </VBox>
    </VBox>
</ScrollPane>