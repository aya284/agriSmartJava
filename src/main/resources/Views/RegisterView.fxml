<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.user.RegisterController"
            style="-fx-background-color: #f4f6f8;">

    <VBox alignment="TOP_CENTER" spacing="20" style="-fx-padding: 40;">

        <Label text="Créer un compte"
               style="-fx-font-size: 26; -fx-font-weight: bold;"/>
        <Label text="Rejoignez AgriSmart"
               style="-fx-text-fill: #777;"/>

        <VBox maxWidth="480" spacing="4">

            <!-- ── Prénom / Nom ── -->
            <HBox spacing="10">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <TextField fx:id="firstNameField" promptText="Prénom *"
                               maxWidth="Infinity"/>
                    <Label fx:id="errFirstName" visible="false"
                           style="-fx-text-fill:#e74c3c; -fx-font-size:11;"/>
                </VBox>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <TextField fx:id="lastNameField" promptText="Nom *"
                               maxWidth="Infinity"/>
                    <Label fx:id="errLastName" visible="false"
                           style="-fx-text-fill:#e74c3c; -fx-font-size:11;"/>
                </VBox>
            </HBox>

            <!-- ── Email ── -->
            <VBox spacing="2" style="-fx-padding: 6 0 0 0;">
                <TextField fx:id="emailField" promptText="Adresse e-mail *"/>
                <Label fx:id="errEmail" visible="false"
                       style="-fx-text-fill:#e74c3c; -fx-font-size:11;"/>
            </VBox>

            <!-- ── Rôle ── -->
            <VBox spacing="2" style="-fx-padding: 6 0 0 0;">
                <ComboBox fx:id="roleComboBox"
                          promptText="Type de compte *" maxWidth="Infinity"/>
                <Label fx:id="errRole" visible="false"
                       style="-fx-text-fill:#e74c3c; -fx-font-size:11;"/>
            </VBox>

            <!-- ── Mot de passe ── -->
            <VBox spacing="2" style="-fx-padding: 6 0 0 0;">
                <PasswordField fx:id="passwordField"
                               promptText="Mot de passe * (8+ cars, A-Z, 0-9, spécial)"/>
                <Label fx:id="errPassword" visible="false"
                       style="-fx-text-fill:#e74c3c; -fx-font-size:11;"/>
            </VBox>

            <!-- ── Confirmer mot de passe ── -->
            <VBox spacing="2" style="-fx-padding: 6 0 0 0;">
                <PasswordField fx:id="confirmPasswordField"
                               promptText="Confirmer le mot de passe *"/>
                <Label fx:id="errConfirm" visible="false"
                       style="-fx-text-fill:#e74c3c; -fx-font-size:11;"/>
            </VBox>

            <!-- ── Téléphone ── -->
            <VBox spacing="2" style="-fx-padding: 6 0 0 0;">
                <TextField fx:id="phoneField"
                           promptText="Téléphone (ex: 22123456)"/>
                <Label fx:id="errPhone" visible="false"
                       style="-fx-text-fill:#e74c3c; -fx-font-size:11;"/>
            </VBox>

            <!-- ── Adresse ── -->
            <VBox spacing="2" style="-fx-padding: 6 0 0 0;">
                <TextField fx:id="addressField" promptText="Adresse"/>
                <Label fx:id="errAddress" visible="false"
                       style="-fx-text-fill:#e74c3c; -fx-font-size:11;"/>
            </VBox>

            <Separator style="-fx-padding: 6 0;"/>

            <!-- ── Photo de profil ── -->
            <Label text="Photo de profil (JPEG / PNG — max 5 Mo)"
                   style="-fx-text-fill:#555; -fx-font-weight:bold;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ImageView fx:id="profilePreview" fitWidth="64" fitHeight="64"
                           preserveRatio="true"
                           style="-fx-effect: dropshadow(gaussian,#aaa,4,0,0,1);"/>
                <VBox spacing="4">
                    <Button text="📷  Choisir une image"
                            onAction="#handleChooseImage"/>
                    <Label fx:id="imageFileLabel" text="Aucun fichier choisi"
                           style="-fx-text-fill:#999; -fx-font-size:11;"/>
                    <Label fx:id="errImage" visible="false"
                           style="-fx-text-fill:#e74c3c; -fx-font-size:11;"/>
                </VBox>
            </HBox>

            <!-- ── Document justificatif ── -->
            <Label text="Document justificatif (PDF / JPEG / PNG — max 5 Mo)"
                   style="-fx-text-fill:#555; -fx-font-weight:bold;
                          -fx-padding: 6 0 0 0;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="📎  Choisir un document"
                        onAction="#handleChooseDocument"/>
                <VBox spacing="4">
                    <Label fx:id="documentFileLabel" text="Aucun fichier choisi"
                           style="-fx-text-fill:#999; -fx-font-size:11;"/>
                    <Label fx:id="errDocument" visible="false"
                           style="-fx-text-fill:#e74c3c; -fx-font-size:11;"/>
                </VBox>
            </HBox>

            <Separator style="-fx-padding: 6 0;"/>

            <!-- ── Message global succès ── -->
            <Label fx:id="successLabel" visible="false" wrapText="true"
                   maxWidth="480"
                   style="-fx-text-fill:#27ae60; -fx-font-size:12;
                          -fx-font-weight:bold;"/>

            <!-- ── Bouton inscription ── -->
            <Button fx:id="registerBtn" text="Créer le compte"
                    onAction="#handleRegister" maxWidth="Infinity"
                    style="-fx-background-color:#2ecc71; -fx-text-fill:white;
                           -fx-font-weight:bold; -fx-padding:10;
                           -fx-font-size:14;"/>

            <!-- ── Lien login ── -->
            <HBox alignment="CENTER" spacing="4">
                <Label text="Déjà inscrit ?"/>
                <Hyperlink text="Se connecter" onAction="#goToLogin"/>
            </HBox>

        </VBox>
    </VBox>
</ScrollPane>