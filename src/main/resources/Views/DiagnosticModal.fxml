<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.DiagnosticController" spacing="20" prefWidth="800" prefHeight="650" style="-fx-background-color: white; -fx-border-radius: 12; -fx-background-radius: 12;">
    <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>

    <!-- En-tête -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="🔬 Diagnostic IA (Plant.id)" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblCultureContext" text="Culture: -" style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px; -fx-font-style: italic;"/>
    </HBox>

    <Separator/>

    <ScrollPane fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox spacing="20" style="-fx-padding: 5;">
            <!-- Zone d'upload et affichage de l'image -->
            <StackPane fx:id="imageContainer" prefHeight="350" style="-fx-background-color: #f8f9fa; -fx-border-color: #bdc3c7; -fx-border-style: dashed; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" onMouseClicked="#handleImageClick">
                <VBox fx:id="uploadPromptBox" alignment="CENTER" spacing="15">
                    <Label text="📸" style="-fx-font-size: 48px;"/>
                    <Label text="Cliquez ici pour sélectionner une photo de la feuille" style="-fx-font-size: 15px; -fx-text-fill: #7f8c8d;"/>
                </VBox>
                <ImageView fx:id="imageView" fitWidth="580" fitHeight="330" preserveRatio="true" visible="false"/>
                
                <!-- Scanner laser (Animation) -->
                <Rectangle fx:id="scannerLine" width="580" height="4" fill="#00d2d3" visible="false" translateY="-165"/>
            </StackPane>

            <!-- Zone de statut de l'analyse -->
            <VBox fx:id="loadingBox" alignment="CENTER" spacing="15" visible="false" managed="${loadingBox.visible}">
                <ProgressIndicator prefWidth="40" prefHeight="40" style="-fx-progress-color: #27ae60;"/>
                <Label text="Analyse IA en cours via Plant.id... ⏳" style="-fx-font-size: 14px; -fx-text-fill: #27ae60; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Zone des Résultats -->
            <VBox fx:id="resultsBox" spacing="20" visible="false" managed="${resultsBox.visible}">
                
                <HBox spacing="15">
                    <!-- Statut global de la plante -->
                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 15; -fx-background-color: #f4f6f7; -fx-border-color: #d1d8e0; -fx-border-radius: 8; -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
                        <Label text="État Général :" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                        <Label fx:id="lblStatus" text="-" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 4 10; -fx-border-radius: 15; -fx-background-radius: 15;"/>
                    </HBox>

                    <!-- Détails Maladie -->
                    <VBox alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-background-color: #fcf3cf; -fx-border-color: #f1c40f; -fx-border-radius: 8; -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
                        <Label text="Maladie Détectée :" style="-fx-font-size: 13px; -fx-text-fill: #d35400;"/>
                        <Label fx:id="lblDiseaseName" text="-" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #c0392b;"/>
                    </VBox>
                </HBox>

                <!-- Traitement -->
                <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: #f0fbf8; -fx-border-color: #2ecc71; -fx-border-radius: 8; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(46,204,113,0.2), 5, 0, 0, 2);">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="💊" style="-fx-font-size: 20px;"/>
                        <Label text="Traitements recommandés" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                    </HBox>
                    <Separator style="-fx-background-color: #2ecc71;"/>
                    <Label fx:id="lblTreatment" text="-" wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #34495e; -fx-line-spacing: 5px;"/>
                </VBox>
            </VBox>
        </VBox>
    </ScrollPane>

    <!-- Boutons d'action -->
    <HBox alignment="CENTER" spacing="15">
        <Button text="Fermer le diagnostic" onAction="#closeModal" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 30; -fx-cursor: hand; -fx-font-weight: bold; -fx-border-radius: 8; -fx-background-radius: 8;"/>
    </HBox>
</VBox>
