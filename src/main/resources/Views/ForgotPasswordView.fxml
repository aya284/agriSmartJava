<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.user.ForgotPasswordController"
      style="-fx-background-color: #f4f6f8; -fx-padding: 60;">

    <Label text="Mot de passe oublié"
           style="-fx-font-size: 26; -fx-font-weight: bold;"/>
    <Label text="Saisissez votre e-mail pour recevoir un jeton de réinitialisation."
           style="-fx-text-fill: #777;" wrapText="true" maxWidth="380"/>

    <VBox maxWidth="380" spacing="12">
        <TextField fx:id="emailField" promptText="Adresse e-mail"/>

        <Label fx:id="statusLabel" visible="false" wrapText="true" maxWidth="380"/>

        <Button fx:id="sendBtn" text="Envoyer"
                onAction="#handleSendReset" maxWidth="Infinity"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand;"/>

        <Separator/>

        <HBox alignment="CENTER" spacing="12">
            <Hyperlink text="← Retour à la connexion" onAction="#goToLogin"/>
            <Label text="|" style="-fx-text-fill: #ccc;"/>
            <Hyperlink text="J'ai déjà un jeton" onAction="#goToResetForm"/>
        </HBox>
    </VBox>
</VBox>