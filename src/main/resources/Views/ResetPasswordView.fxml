<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.user.ResetPasswordController"
      style="-fx-background-color: #f4f6f8; -fx-padding: 60;">

    <Label text="Réinitialiser le mot de passe"
           style="-fx-font-size: 24; -fx-font-weight: bold;"/>
    <Label text="Saisissez le code OTP reçu par e-mail, puis choisissez un nouveau mot de passe."
           style="-fx-text-fill: #555555; -fx-font-size: 14px;"
           wrapText="true" maxWidth="380"/>

    <VBox maxWidth="380" spacing="16" alignment="CENTER">

        <!-- ── 6-Digit OTP Boxes ── -->
        <HBox fx:id="otpBox" spacing="10" alignment="CENTER">
            <TextField fx:id="otp1" prefWidth="52" prefHeight="58" maxWidth="52"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-alignment: center; -fx-background-radius: 12;
                              -fx-border-color: #d1d5db; -fx-border-width: 2;
                              -fx-border-radius: 12; -fx-background-color: white;"/>
            <TextField fx:id="otp2" prefWidth="52" prefHeight="58" maxWidth="52"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-alignment: center; -fx-background-radius: 12;
                              -fx-border-color: #d1d5db; -fx-border-width: 2;
                              -fx-border-radius: 12; -fx-background-color: white;"/>
            <TextField fx:id="otp3" prefWidth="52" prefHeight="58" maxWidth="52"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-alignment: center; -fx-background-radius: 12;
                              -fx-border-color: #d1d5db; -fx-border-width: 2;
                              -fx-border-radius: 12; -fx-background-color: white;"/>
            <TextField fx:id="otp4" prefWidth="52" prefHeight="58" maxWidth="52"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-alignment: center; -fx-background-radius: 12;
                              -fx-border-color: #d1d5db; -fx-border-width: 2;
                              -fx-border-radius: 12; -fx-background-color: white;"/>
            <TextField fx:id="otp5" prefWidth="52" prefHeight="58" maxWidth="52"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-alignment: center; -fx-background-radius: 12;
                              -fx-border-color: #d1d5db; -fx-border-width: 2;
                              -fx-border-radius: 12; -fx-background-color: white;"/>
            <TextField fx:id="otp6" prefWidth="52" prefHeight="58" maxWidth="52"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-alignment: center; -fx-background-radius: 12;
                              -fx-border-color: #d1d5db; -fx-border-width: 2;
                              -fx-border-radius: 12; -fx-background-color: white;"/>
        </HBox>

        <!-- Password Fields -->
        <PasswordField fx:id="newPasswordField"
                       promptText="Nouveau mot de passe"
                       maxWidth="380"
                       style="-fx-background-radius: 10; -fx-padding: 12;
                              -fx-border-color: #d1d5db; -fx-border-width: 1;
                              -fx-border-radius: 10; -fx-font-size: 14px;"/>
        <PasswordField fx:id="confirmPasswordField"
                       promptText="Confirmer le mot de passe"
                       maxWidth="380"
                       style="-fx-background-radius: 10; -fx-padding: 12;
                              -fx-border-color: #d1d5db; -fx-border-width: 1;
                              -fx-border-radius: 10; -fx-font-size: 14px;"/>

        <Label fx:id="statusLabel" visible="false" wrapText="true" maxWidth="380"/>

        <Button fx:id="resetBtn" text="Réinitialiser"
                onAction="#handleReset" maxWidth="380"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-padding: 12;
                       -fx-background-radius: 10; -fx-cursor: hand;
                       -fx-font-size: 14px;"/>

        <HBox alignment="CENTER">
            <Hyperlink text="← Retour à la connexion" onAction="#goToLogin"/>
        </HBox>

    </VBox>
</VBox>