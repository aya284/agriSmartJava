<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.user.ResetPasswordController"
      style="-fx-background-color: #f4f6f8; -fx-padding: 60;">

    <Label text="Réinitialiser le mot de passe"
           style="-fx-font-size: 24; -fx-font-weight: bold;"/>
    <Label text="Collez le jeton reçu par e-mail, puis choisissez un nouveau mot de passe."
           style="-fx-text-fill: #777;" wrapText="true" maxWidth="380"/>

    <VBox maxWidth="380" spacing="12">
        <TextField     fx:id="tokenField"           promptText="Coller le jeton ici"/>
        <PasswordField fx:id="newPasswordField"     promptText="Nouveau mot de passe"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirmer le mot de passe"/>

        <Label fx:id="statusLabel" visible="false" wrapText="true" maxWidth="380"/>

        <Button fx:id="resetBtn" text="Réinitialiser"
                onAction="#handleReset" maxWidth="Infinity"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand;"/>

        <HBox alignment="CENTER">
            <Hyperlink text="← Retour à la connexion" onAction="#goToLogin"/>
        </HBox>
    </VBox>
</VBox>