<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox spacing="0.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AdminOffreController">

    <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-padding: 20 40; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 0);">
        <Button onAction="#goBackToTable" style="-fx-background-color: #f1f2f6; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-weight: bold;" text="← Retour au tableau" />
        <Separator orientation="VERTICAL" prefHeight="30.0" />
        <VBox>
            <Label fx:id="adminDetailTitle" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Titre de l'offre" />
            <Label text="Consultation du dossier d'offre" style="-fx-text-fill: #95a5a6; -fx-font-size: 12;" />
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f8f9fa;">
        <VBox spacing="25.0" style="-fx-padding: 30 40;">

            <HBox spacing="25.0">
                <VBox spacing="20.0" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);" HBox.hgrow="ALWAYS">
                    <VBox spacing="10">
                        <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1a3323;" text="📝 Description complète" />
                        <Separator />
                        <Label fx:id="adminDetailDesc" style="-fx-font-size: 15; -fx-text-fill: #34495e; -fx-line-spacing: 5;" text="Description text here..." wrapText="true" />
                    </VBox>
                </VBox>

                <VBox prefWidth="350.0" spacing="20.0">
                    <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="📍 Localisation" />
                        <Label fx:id="adminDetailLieu" style="-fx-font-size: 14; -fx-text-fill: #2c3e50; -fx-background-color: #f1f2f6; -fx-padding: 10; -fx-background-radius: 8;" text="Lieu" maxWidth="Infinity"/>

                        <Separator />

                        <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="🛡 Statut de Validation" />
                        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f1f2f6; -fx-padding: 10; -fx-background-radius: 8;">
                            <Circle radius="5" fill="#27ae60" fx:id="statusDot"/>
                            <Label fx:id="adminDetailStatus" style="-fx-font-weight: bold; -fx-font-size: 14;" text="Statut" />
                        </HBox>
                    </VBox>
                </VBox>
            </HBox>

        </VBox>
    </ScrollPane>
</VBox>